    { symbol: 'BANK NIFTY', price: '48,250.60', change: '+0.45%' },
    { symbol: 'RELIANCE', price: '2,910.40', change: '+1.20%' },
    { symbol: 'HDFC BANK', price: '1,560.15', change: '+0.30%' },
