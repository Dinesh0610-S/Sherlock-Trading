    riskPercent: '1.0',
    lotSize: '25'
  });
  const [rrResults, setRrResults] = useState({
    rrRatio1: '1:1.0',
    rrRatio2: '1:2.0',
    maxRisk: '1000',
    maxProfit: '2000',
    positionSize: '15',
    verdict: 'ACCEPTABLE SETUP',
    verdictClass: 'neutral',
