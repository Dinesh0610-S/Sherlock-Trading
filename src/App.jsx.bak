  // Send message in Chat Console
  const handleSendChat = async (e, customMsg = null) => {
    if (e && e.preventDefault) e.preventDefault();
    const queryText = customMsg !== null ? customMsg : chatInput;
    if (!queryText.trim()) return;

    setChatMessages(prev => [...prev, { sender: 'user', text: queryText }]);
    if (customMsg === null) setChatInput('');
    setLoadingChat(true);
    setIsStreaming(true);
    setStreamedReply('');

    try {
      const res = await fetch('/api/chat', {
        method: 'POST',
        headers: { 'Content-Type': 'application/json' },
        body: JSON.stringify({
          message: queryText,
          ticker: selectedAsset,
          history: chatMessages.map(m => ({ sender: m.sender, text: m.text })),
          metrics: {
            spot_price: Number(indicators?.spot_price || 23664.35),
            rsi: Number(indicators?.rsi || 50.0),
            ema_status: String(indicators?.ema_status || 'NEUTRAL'),
            vwap_val: Number(indicators?.vwap_val || 23664.35),
            spot_below_ema21: typeof indicators?.spot_below_ema21 === 'boolean' ? indicators.spot_below_ema21 : false,
            pcr: Number(indicators?.pcr || 1.0),
            max_pain: Number(indicators?.max_pain || 23500.0)
          }
        })
      });

      if (!res.ok) {
        throw new Error("Failed to connect to Sherlock's deductive threads.");
      }

      const reader = res.body.getReader();
      const decoder = new TextDecoder();
      let fullText = '';

      while (true) {
        const { done, value } = await reader.read();
        if (done) break;

        const chunk = decoder.decode(value);
        const lines = chunk.split('\n').filter(l => l.startsWith('data: '));

        for (const line of lines) {
          const dataStr = line.replace('data: ', '').trim();
          if (dataStr === '[DONE]') break;
          try {
            const parsed = JSON.parse(dataStr);
            const token = parsed.delta?.text || '';
            fullText += token;
            setStreamedReply(fullText);
          } catch (err) {
            console.error("Error parsing token chunk:", err);
          }
        }
      }

      setChatMessages(prev => [...prev, {
        sender: 'sherlock',
        text: fullText
      }]);
    } catch (err) {
      setChatMessages(prev => [...prev, {
        sender: 'sherlock',
        text: "Indubitably, Watson, my cognitive threads encountered a momentary delay: " + err.message
      }]);
    } finally {
      setLoadingChat(false);
      setIsStreaming(false);
      setStreamedReply('');
    }
  };

  // Client-Side RR Calculations
  const calculateRR = () => {
    const entry = parseFloat(rrForm.entry);
    const sl = parseFloat(rrForm.sl);
    const t1 = parseFloat(rrForm.target1);
    const t2 = parseFloat(rrForm.target2);
    const t3 = parseFloat(rrForm.target3 || (entry + (entry - sl) * 3));
    const cap = parseFloat(rrForm.totalCapital);
    const rPct = parseFloat(rrForm.riskPercent);
    const lotSize = parseInt(rrForm.lotSize);
    const tradeType = rrForm.tradeType || 'CE';
    const instrument = rrForm.asset || 'NIFTY';

    if (isNaN(entry) || isNaN(sl) || isNaN(t1) || isNaN(t2) || isNaN(cap) || isNaN(rPct) || isNaN(lotSize)) return;

    const slPoints = Math.abs(entry - sl);
    if (slPoints <= 0) {
      setRrResults({
        lots: 0,
        lotSize,
        actualRisk: 0,
        margin: 0,
        kellyLots: 0,
        scenarios: [],
        projectedMonthly: 0,
        warnings: ['⚠ Invalid Stop Loss — must not equal entry price'],
        verdict: 'INVALID SL',
        verdictClass: 'bearish'
      });
      return;
    }

    const riskAmount = cap * (rPct / 100);
    const lotsRaw = riskAmount / (slPoints * lotSize);
    const lots = Math.max(1, Math.floor(lotsRaw));
    const actualRisk = lots * lotSize * slPoints;

    // Margin calculation
    let marginPerLot = 120000; // standard margin for selling options/futures in India (approx 1.2L INR)
    if (tradeType === 'CE' || tradeType === 'PE') {
      // Option buying margin is just the premium * lot size
      marginPerLot = entry * lotSize;
    }
    const margin = marginPerLot * lots;

    // Kelly Criterion check
    const winRate = 0.55; // conservative estimate
    const avgWin = Math.abs(t2 - entry);
    const avgLoss = slPoints;
    const kellyPct = winRate - ((1 - winRate) / (avgWin / avgLoss));
    const kellyLots = Math.max(1, Math.floor((cap * Math.max(0, kellyPct)) / marginPerLot));

    // Scenarios
    const scenarios = [
      {
        label:  'Best Case (T3)',
        price:  t3,
        profit: lots * lotSize * Math.abs(t3 - entry),
        rr:     (Math.abs(t3 - entry) / slPoints).toFixed(1)
      },
      {
        label:  'Base Case (T2)',
        price:  t2,
        profit: lots * lotSize * Math.abs(t2 - entry),
        rr:     (Math.abs(t2 - entry) / slPoints).toFixed(1)
      },
      {
        label:  'Conservative (T1)',
        price:  t1,
        profit: lots * lotSize * Math.abs(t1 - entry),
        rr:     (Math.abs(t1 - entry) / slPoints).toFixed(1)
      },
      {
        label:  'Stop Loss Hit',
        price:  sl,
        profit: -actualRisk,
        rr:     '1:0'
      }
    ];

    // Projections
    const monthlyTrades = 22; // 22 trading days
    const projectedMonthly =
      scenarios[1].profit * (winRate * monthlyTrades) -
      actualRisk * ((1 - winRate) * monthlyTrades);

    // Warnings
    const warnings = [
      margin > cap * 0.3
        ? '⚠ Margin > 30% of capital — reduce lots'
        : null,
      actualRisk > cap * 0.02
        ? '⚠ Risk > 2% of capital — dangerous'
        : null,
      lots > kellyLots
        ? `⚠ Kelly suggests max ${kellyLots} lots`
        : null
    ].filter(Boolean);

    setRrResults({
      lots,
      lotSize,
      actualRisk,
      margin,
      kellyLots: Math.min(lots, kellyLots),
      scenarios,
      projectedMonthly,
      warnings,
      verdict: actualRisk > cap * 0.02 ? 'REJECT SETUP — EXCESSIVE RISK' : 'A+ POSITION SETUP',
      verdictClass: actualRisk > cap * 0.02 ? 'bearish' : 'bullish'
    });
  };

  // Run Monte Carlo Simulation
  const handleRunSimulation = () => {
    const wRate = parseFloat(simForm.winRate) / 100;
    const numTr = parseInt(simForm.numTrades);
    const rAmt = parseFloat(simForm.riskPerTrade);
    const rRatio = parseFloat(simForm.rewardRatio);

    if (isNaN(wRate) || isNaN(numTr) || isNaN(rAmt) || isNaN(rRatio)) return;

    // Simulate 5 curves
    const datasets = [];
    const colors = [
      'rgba(0, 201, 167, 0.75)',
      'rgba(77, 166, 255, 0.75)',
      'rgba(201, 168, 76, 0.75)',
      'rgba(255, 179, 71, 0.75)',
      'rgba(0, 230, 118, 0.75)'
    ];

    for (let c = 0; c < 5; c++) {
      let balance = 100000;
      const data = [balance];
      for (let i = 0; i < numTr; i++) {
        const win = Math.random() < wRate;
        if (win) {
          balance += rAmt * rRatio;
        } else {
          balance -= rAmt;
        }
        data.push(balance);
      }
      datasets.push({
        label: `Simulation Run ${c + 1}`,
        data: data,
        borderColor: colors[c],
        borderWidth: 1.5,
        pointRadius: 0,
        fill: false
      });
    }

    const labels = Array.from({ length: numTr + 1 }, (_, i) => i.toString());
    setSimChartData({
      labels: labels,
      datasets: datasets
    });
  };

