          confidence: json.confidence > 1 ? json.confidence / 100 : (json.confidence || 0.5)
        };
        setFiiDiiAnalysis(normalized);
        setFiiDiiAnalysisTime(Date.now());
      }
    } catch (e) {
      console.error('Error analyzing FII/DII flows:', e);
